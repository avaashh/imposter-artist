# Backend — server/main.go
# Comma-separated list of allowed WebSocket origins. Use * to allow any.
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Frontend — read by src/assets/dist/server.ts at build time.
# Omit to auto-detect from window.location (wss://<host>:<port>/ws).
REACT_APP_WS_URL=ws://localhost:8000/ws
